hostgalaxy_constraints:
  search_radius_arcsec: 600
  max_dell: 1.5
  max_distance: 200.0   
  min_distance: 1.0     

magnitude_constraints:
  candidate_magabspsf: [">-18", "<-10"]

magnitude_constraints:
  candidate_magabspsf:
    and: [">-18", "<-10"]

catalog_constraints:
  # Basic filtering
  gaiaVarFlag: "==0"
  anomaly_score: "<0.5"
  jdstarthist_dt: "<10"
  is_transient: true

  # Machine learning probabilities
  snn_snia_vs_nonia: ">0.7"
  snn_sn_vs_all: ">0.7"

  # Candidate properties
  candidate_sigmapsf: "<0.2"
  candidate_dec: "<20"
  candidate_magpsf: "<20"
  candidate_classtar: ">0.5"
  candidate_rb: ">0.7"

  candidate_neargaia:
    or: [">5", "<0"]

  candidate_neargaiabright:
    or: [">10", "<0"]

  # Optional (currently disabled in code)
  # nalerthist: "<5"
  # candidate_ndethist: "<5"


