    "\n",
    "                detection_tbl = self.alerce.query_detections(alert_instance.objname)\n",
    "                if 'magpsf_cordd' in detection_tbl.columns:\n",
    "                    magnitude = detection_tbl['magpsf_corr']\n",
    "                else:\n",
    "                    magnitude = detection_tbl['magpsf']\n",
    "                try:\n",
    "                    detection_tbl = detection_tbl[magnitude.mask]\n",
    "                except:\n",
    "                    pass\n",
    "                mjd_now = Time.now().mjd\n",
    "                closest_idx = np.argmin(np.abs(detection_tbl['mjd'] - mjd_now))\n",
    "                magnitude = magnitude[closest_idx]\n",
    "                distance_modulus = 5 * np.log10(float(alert_instance.host_galaxy_distance)) +25\n",
    "                alert_instance.mag_expected = round(float(magnitude),2)\n",
    "                alert_instance.absmag_expected = round(float(magnitude - distance_modulus),2)\n",
    "\n"
   ]
  },
