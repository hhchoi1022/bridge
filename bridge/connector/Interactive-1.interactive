   "source": [
    "        alerce_tbl_recent = alerce_tbl[(alerce_tbl['mjdstarthist'] > mjd_start) & (alerce_tbl['meandec'] < self.config.decl_upper) & (alerce_tbl['meandec'] > self.config.decl_lower)]\n",
    "        print(f\"{len(alerce_tbl_recent)} new alerts are found!\")\n",
    "        for alerce_alert in tqdm(alerce_tbl_recent, desc = 'Checking alerts...'):\n",
    "            \n",
    "            alert_instance = Alert(\n",
    "                cent_ra = float(alerce_alert['meanra']),\n",
    "                cent_dec = float(alerce_alert['meandec']),\n",
    "                objname = str(alerce_alert['oid']),\n",
    "                alert_time = Time(alerce_alert['firstmjd'], format='mjd'),\n",
    "                )\n",
    "            \n",
    "            alert_instance = self.check_alert(alert_instance)\n",
    "            if not alert_instance is None:\n",
    "                print(\"NEW ALERT FOUND!\") \n",
    "                break\n",
    "\n"
   ]
