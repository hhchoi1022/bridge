   "source": [
    "from astropy.table.table import TableColumns\n",
    "from pathlib import Path\n",
    "import json\n",
    "from typing import Any\n",
    "from astropy.time import Time\n",
    "from astropy.table import Table\n",
    "from astropy.coordinates import SkyCoord\n",
    "import astropy.units as u\n",
    "import numpy as np\n",
    "from tqdm import tqdm\n",
    "import time\n",
    "from collections import deque\n",
    "import datetime\n",
    "\n",
    "from bridge.configuration import Configuration\n",
    "from bridge.alertquerier import ALERCEQuerier\n",
    "from bridge.alertquerier import TNSQuerier\n",
    "from bridge.utils import HostGalaxyCatalog\n",
    "from bridge.objects import Alert\n",
    "from bridge.connector import SQLConnector, SDSConnector, GmailConnector"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "9f28fb88-8f14-4387-9d19-4647a1dd436f",
   "metadata": {},
   "outputs": [],
   "source": [
    "class AlertTrigger:\n",
    "    def __init__(self):\n",
    "        self.config = Configuration(config_filenames=['alerttrigger.config'])\n",
    "        self.initialize()\n",
    "        self.trigger_history = deque(maxlen=20)  # keep last 20 trigger timestamps\n",
    "\n",
    "    def initialize(self):\n",
    "        print('Start initializing the AlertTrigger...')\n",
    "        self.alerce = ALERCEQuerier()\n",
    "        self.tns = TNSQuerier()\n",
    "        self.hostgalaxycatalog = HostGalaxyCatalog()\n",
    "        # Cut hostgalaxy catalog\n",
    "        self.hostgalaxycatalog.cut_catalog(z_final = '<' + str(self.config.hostgal_maxdist_redshift), distance_final = '<' + str(self.config.hostgal_maxdist_Mpc))\n",
    "        self.db = SQLConnector()\n",
    "        self.sds = SDSConnector()\n",
    "        self.mail = GmailConnector()\n",
    "        print('AlertTrigger initialized successfully!')\n",
    "        \n",
    "    def receive_alerts(self):\n",
    "        mjd_start = Time.now().mjd - self.config.search_days\n",
    "        \n",
    "        # ALERCE Alert broker. (Receive -> Update DB -> Trigger)\n",
    "        alerce_tbl = self.alerce.query_objects(\n",
    "            class_name = self.alerce.config.classname,\n",
    "            probability = self.alerce.config.probability,\n",
    "            firstmjd = mjd_start,\n",
    "            lastmjd = None,\n",
    "            page = 1,\n",
    "            page_size = 1000000\n",
    "        )\n",
    "        if len(alerce_tbl) == 0:\n",
    "            print('No alerts found!')\n",
    "            return\n",
    "        alerce_tbl_recent = alerce_tbl[(alerce_tbl['mjdstarthist'] > mjd_start) & (alerce_tbl['meandec'] < self.config.decl_upper) & (alerce_tbl['meandec'] > self.config.decl_lower)]\n",
    "        print(f\"{len(alerce_tbl_recent)} new alerts are found!\")\n",
    "        for alerce_alert in tqdm(alerce_tbl_recent, desc = 'Checking alerts...'):\n",
    "            \n",
    "            alert_instance = Alert(\n",
    "                cent_ra = float(alerce_alert['meanra']),\n",
    "                cent_dec = float(alerce_alert['meandec']),\n",
    "                objname = str(alerce_alert['oid']),\n",
    "                alert_time = Time(alerce_alert['firstmjd'], format='mjd'),\n",
    "                )\n",
    "            \n",
    "            alert_instance = self.check_alert(alert_instance)\n",
    "            if not alert_instance is None:\n",
    "                print(\"NEW ALERT FOUND!\") \n",
    "                detection_tbl = self.alerce.query_detections(alert_instance.objname)\n",
    "                if 'magpsf_cordd' in detection_tbl.columns:\n",
    "                    magnitude = detection_tbl['magpsf_corr']\n",
    "                else:\n",
    "                    magnitude = detection_tbl['magpsf']\n",
    "                try:\n",
    "                    detection_tbl = detection_tbl[magnitude.mask]\n",
    "                except:\n",
    "                    pass\n",
    "                mjd_now = Time.now().mjd\n",
    "                closest_idx = np.argmin(np.abs(detection_tbl['mjd'] - mjd_now))\n",
    "                magnitude = magnitude[closest_idx]\n",
    "                distance_modulus = 5 * np.log10(float(alert_instance.host_galaxy_distance)) +25\n",
    "                alert_instance.mag_expected = round(float(magnitude),2)\n",
    "                alert_instance.absmag_expected = round(float(magnitude - distance_modulus),2)\n",
    "                self.insert_alert_db_info(alert_instance)\n",
    "                \n",
    "    def get_alerts_db(self):\n",
    "        data = self.db.get_data(tbl_name = 'transient_info', select_key = '*')\n",
    "        if len(data) == 0:\n",
    "            return None\n",
    "        \n",
    "        alertlist = []\n",
    "        for row in data:\n",
    "            alert_instance = Alert(\n",
    "                cent_ra = float(row['cent_ra']),\n",
    "                cent_dec = float(row['cent_dec']),\n",
    "                objname = str(row['objname']),\n",
    "                alert_time = Time(row['alert_time']),\n",
    "                alert_id = str(row['alert_id']),\n",
    "                create_time = Time(row['create_time']),\n",
    "                trigger_time = Time(row['trigger_time']),\n",
    "                is_triggered = bool(row['is_triggered']),\n",
    "                radius = float(row['radius_arcsec']),\n",
    "                \n",
    "                exptime = float(row['exptime']),\n",
    "                count = int(row['count']),\n",
    "                obsmode = str(row['obsmode']),\n",
    "                filter_ = str(row['filter_']),\n",
    "                specmode = str(row['specmode']),\n",
    "                ntelescope = int(row['ntelescope']),\n",
    "                priority = int(row['priority']),\n",
    "                weight = int(row['weight']),\n",
    "                binning = int(row['binning']),\n",
    "                gain = int(row['gain']),\n",
    "                objtype = str(row['objtype']),\n",
    "                is_ToO = int(row['is_ToO']),\n",
    "                is_rapid_ToO = bool(row['is_rapid_ToO']),\n",
    "                \n",
    "                note = str(row['note']),\n",
    "                host_galaxy = str(row['host_galaxy']),\n",
    "                host_galaxy_distance = float(row['host_galaxy_distance']),\n",
    "                host_galaxy_separation = float(row['host_galaxy_separation']),\n",
    "                mag_expected = float(row['mag_expected']),\n",
    "                absmag_expected = float(row['absmag_expected']),\n",
    "            )\n",
    "            alertlist.append(alert_instance)\n",
    "        return alertlist\n",
    "    \n",
    "\n",
    "    def _trigger_with_rate_limit(self):\n",
    "        while self.alert_list:\n",
    "            alert_instance = self.alert_list.pop(0)\n",
    "            self.trigger_alert(alert_instance)\n",
    "\n",
    "            now = time.time()\n",
    "            self.trigger_history.append(now)\n",
    "\n",
    "            # Count how many triggers in last 10 minutes\n",
    "            recent_triggers = [t for t in self.trigger_history if now - t <= 600]\n",
    "\n",
    "            if len(recent_triggers) > 2:\n",
    "                print(\"⚠️ More than 2 triggers in 1 min → waiting 5 min\")\n",
    "                time.sleep(300)  # wait 5 minutes\n",
    "            else:\n",
    "                print(\"Sleeping 1 min before next trigger\")\n",
    "                time.sleep(60)   # normal 1 minutes\n",
    "                \n",
    "    def trigger_alert(self, alert_instance: Alert):\n",
    "        # Input ToO status \n",
    "        # Send ToO observation mail (Trigger ToO observation)\n",
    "        self.send_mail(alert_instance)\n",
    "        alert_instance.is_triggered = True\n",
    "        alert_instance.trigger_time = Time.now()\n",
    "        self.input_trigger_status(alert_instance)\n",
    "        self.update_alert_db(alert_instance)\n",
    "        \n",
    "    def check_alert(self, alert_instance: Alert):\n",
    "        progress = {\n",
    "            \"Already in DB\": False,\n",
    "            \"Visibility (now/tonight)\": False,\n",
    "            \"Host galaxy\": False,\n",
    "            \"Detections & stamp\": False,\n",
    "        }\n",
    "\n",
    "        # 1. Already in DB\n",
    "        alert_in_db = self.get_alert_db_info(objname=alert_instance.objname,\n",
    "                                           alert_time=alert_instance.alert_time)\n",
    "        if alert_in_db is not None:\n",
    "            self._print_progress(title = alert_instance.objname, progress_dict = progress, stop=\"Already in DB\")\n",
    "            return None\n",
    "        progress[\"Already in DB\"] = True\n",
    "\n",
    "        # 2. Visibility\n",
    "        now = Time.now()\n",
    "        if not alert_instance.is_observable_tonight(now):\n",
    "            self._print_progress(title = alert_instance.objname, progress_dict = progress, stop=\"Not observable tonight\")\n",
    "            return None\n",
    "        progress[\"Visibility (now/tonight)\"] = True\n",
    "\n",
    "        # 3. Host galaxy\n",
    "        host_galaxy_nearby = self.hostgalaxycatalog.search_catalog(\n",
    "            alert_instance.cent_ra, alert_instance.cent_dec, 0.5\n",
    "        )\n",
    "        host_galaxy_within_radius = host_galaxy_nearby[\n",
    "            host_galaxy_nearby['separation'] < host_galaxy_nearby['diameter_final']\n",
    "        ]\n",
    "        if len(host_galaxy_within_radius) == 0:\n",
    "            self._print_progress(title = alert_instance.objname, progress_dict = progress, stop=\"No host galaxy within radius\")\n",
    "            return None\n",
    "        progress[\"Host galaxy\"] = True\n",
    "        \n",
    "        alert_instance.host_galaxy = host_galaxy_within_radius['objname_NED'][0]\n",
    "        alert_instance.host_galaxy_distance = float(host_galaxy_within_radius['distance_final'][0])\n",
    "        alert_instance.host_galaxy_separation = float(host_galaxy_within_radius['separation'][0])\n",
    "        \n",
    "        savepath_visibility = Path(self.config.save_dir) / f'{alert_instance.objname}_visibility.png' if self.config.save_visibility else None\n",
    "        if (self.config.show_visibility) or (self.config.save_visibility):\n",
    "            alert_instance.plot_visibility(utctime = now, \n",
    "                                           show = self.config.show_visibility, \n",
    "                                           save_path = savepath_visibility)\n",
    "        \n",
    "        savepath_stamp = Path(self.config.save_dir) / f'{alert_instance.objname}_stamp.png' if self.config.save_stamp else None\n",
    "        if (self.config.show_stamp) or (self.config.save_stamp):\n",
    "            self.alerce.plot_stamp(object_id = alert_instance.objname, \n",
    "                                   show = self.config.show_stamp, \n",
    "                                   save_path = savepath_stamp)\n",
    "        progress[\"Detections & stamp\"] = True\n",
    "\n",
    "        # Print final result\n",
    "        self._print_progress(title = alert_instance.objname, progress_dict = progress, stop=None)\n",
    "        return alert_instance  # Or whatever you want to return\n",
    "    \n",
    "    def send_mail(self, alert_instance):\n",
    "        \"\"\"\n",
    "        Send email notification for a new alert_instance,\n",
    "        strictly following the ToO email format.\n",
    "        \"\"\"\n",
    "\n",
    "        subject = f\"[Automated] 7DT ToO Observation Request: {alert_instance.objname}\"\n",
    "\n",
    "        email_body = f\"\"\"\n",
    "        ================================\n",
    "        New ToO Request Submitted\n",
    "        ================================\n",
    "\n",
    "        **Observation Information**\n",
    "        ----------------------\n",
    "        - Requester: {self.config.mail_requester}\n",
    "        - Target Name: {alert_instance.objname}\n",
    "        - Right Ascension (R.A.): {alert_instance.cent_ra:.5f}\n",
    "        - Declination (Dec.): {alert_instance.cent_dec:.5f}\n",
    "        - Total Exposure Time (seconds): {alert_instance.exptime * alert_instance.count:.1f}\n",
    "        - Single Exposure Time (seconds): {alert_instance.exptime:.1f}\n",
    "        - # of images: {alert_instance.count}\n",
    "        - Obsmode: {alert_instance.obsmode}\n",
    "\n",
    "        **Detailed Settings**\n",
    "        --------------------\n",
    "        - Abort Current Observation: {alert_instance.is_rapid_ToO}\n",
    "        - Priority: {alert_instance.priority}\n",
    "        - Gain: {alert_instance.gain}\n",
    "        - Radius (arcsec): {alert_instance.radius}\n",
    "        - Binning: {alert_instance.binning}\n",
    "        - Observation Start Time: None\n",
    "        - Comments: Triggered automatically with 7DT SN ToO Project\n",
    "\n",
    "        ================================\n",
    "        Please take necessary actions.\n",
    "        ================================\n",
    "        \"\"\"\n",
    "\n",
    "        try:\n",
    "            self.mail.send_mail(to_users = self.config.mail_recipients, subject = subject, body = email_body)\n",
    "            return True\n",
    "        except Exception as e:\n",
    "            print(f\"❌ Failed to send email for {alert_instance.objname}: {e}\")\n",
    "            return False\n",
    "        \n",
    "                \n",
    "    def input_trigger_status(self, alert_instance: Alert):\n",
    "        colnames = [\n",
    "            'alert_id',\n",
    "            'trigger_time',\n",
    "            'update_time',\n",
    "            'objname',\n",
    "            'tile_id',\n",
    "            ]\n",
    "        \n",
    "        savepath_tile = Path(self.config.save_dir) / f'{alert_instance.objname}_tile.png' if self.config.save_tile else None\n",
    "        matched_tbl = self.sds.find_overlapping_tiles(\n",
    "            list_ra = [alert_instance.cent_ra], \n",
    "            list_dec = [alert_instance.cent_dec], \n",
    "            list_aperture = [alert_instance.radius],\n",
    "            visualize = self.config.show_tile,\n",
    "            save_fig = self.config.save_tile,\n",
    "            visualize_savepath = savepath_tile,\n",
    "            match_tolerance_minutes = self.config.tile_edge_tolerance_minutes,\n",
    "            )[0]\n",
    "        \n",
    "        if alert_instance.trigger_time is None:\n",
    "            trigger_time = None\n",
    "        else:\n",
    "            trigger_time = alert_instance.trigger_time.isot\n",
    "        \n",
    "        # When the alert is not covered by 7DS\n",
    "        if len(matched_tbl) == 0:\n",
    "            tile_id = alert_instance.objname\n",
    "        \n",
    "        else:\n",
    "            if len(matched_tbl) > 1:\n",
    "                alert_instance.is_multitarget = True\n",
    "                for row in matched_tbl:\n",
    "                    tile_id = str(row['id'])\n",
    "                    values = [\n",
    "                        alert_instance.alert_id,\n",
    "                        trigger_time,\n",
    "                        Time.now().isot,\n",
    "                        alert_instance.objname,\n",
    "                        tile_id\n",
    "                    ]\n",
    "                    self.db.insert_rows(tbl_name = 'transient_status', data = Table(names = colnames, rows = [values]))\n",
    "            else:\n",
    "                alert_instance.is_multitarget = False\n",
    "                tile_id = str(matched_tbl['id'][0])\n",
    "                values = [\n",
    "                    alert_instance.alert_id,\n",
    "                    trigger_time,\n",
    "                    Time.now().isot,\n",
    "                    alert_instance.objname,\n",
    "                    tile_id\n",
    "                ]\n",
    "                self.db.insert_rows(tbl_name = 'transient_status', data = Table(names = colnames, rows = [values]))\n",
    "        self.update_alert_db(alert_instance)        \n",
    "    \n",
    "    def update_alert_db_info(self, alert_instance: Alert):\n",
    "        \n",
    "        input_dict = alert_instance.__dict__\n",
    "        # If isinstance(Time), convert to isot\n",
    "        input_dict = {key: Time(value).isot if isinstance(value, (Time, datetime.datetime)) else value for key, value in input_dict.items()}\n",
    "        # If not float, int, str, bool, None, remove\n",
    "        input_dict = {key: value for key, value in input_dict.items() if (np.isscalar(value)) or (value is None)}\n",
    "        # Remove alert_id\n",
    "        keys = input_dict.keys()\n",
    "        values = input_dict.values()\n",
    "        \n",
    "        result = self.db.update_row(tbl_name = 'transient_info', update_value = values, update_key = keys, id_value = alert_instance.alert_id, id_key = 'alert_id')\n",
    "        return result\n",
    "    \n",
    "    def insert_alert_db_info(self, alert_instance: Alert):\n",
    "        input_dict = alert_instance.__dict__\n",
    "        # If isinstance(Time), convert to isot\n",
    "        input_dict = {key: Time(value).isot if isinstance(value, (Time, datetime.datetime)) else value for key, value in input_dict.items()}\n",
    "        # If not float, int, str, bool, None, remove\n",
    "        input_dict = {key: value for key, value in input_dict.items() if (np.isscalar(value)) or (value is None)}\n",
    "        \n",
    "        result = self.db.insert_rows(tbl_name = 'transient_info', data = Table(names = input_dict.keys(), rows = [input_dict.values()]))\n",
    "        return result\n",
    "    \n",
    "    def get_alert_db_info(self, \n",
    "                         idx: int = None,\n",
    "                         alert_id: str = None,\n",
    "                         objname: str = None,\n",
    "                         cent_ra: float = None,\n",
    "                         cent_dec: float = None,\n",
    "                         alert_time: Time = None):\n",
    "        \n",
    "        data = self.db.get_data(tbl_name = 'transient_info', select_key = '*')\n",
    "        if len(data) == 0:\n",
    "            return None\n",
    "        \n",
    "        target_row = data\n",
    "        if idx is not None:\n",
    "            target_row = target_row[idx]\n",
    "        if len(target_row) == 0:\n",
    "            return None\n",
    "        if alert_id is not None:\n",
    "            target_row = target_row[target_row['alert_id'] == alert_id]\n",
    "        if len(target_row) == 0:\n",
    "            return None\n",
    "        if objname is not None:\n",
    "            target_row = target_row[target_row['objname'] == objname]\n",
    "        if len(target_row) == 0:\n",
    "            return None\n",
    "        if cent_ra is not None and cent_dec is not None:\n",
    "            target_coord = SkyCoord(ra = cent_ra * u.deg, dec = cent_dec * u.deg)\n",
    "            data_coord = SkyCoord(ra = target_row['cent_ra'] * u.deg, dec = target_row['cent_dec'] * u.deg)\n",
    "            sep = target_coord.separation(data_coord)\n",
    "            close_idx = np.where(sep < 30 * u.arcsec)[0]\n",
    "            target_row = target_row[close_idx]\n",
    "        if len(target_row) == 0:\n",
    "            return None\n",
    "        if alert_time is not None:\n",
    "            alert_time = Time(alert_time)\n",
    "            db_alert_time = Time(target_row['alert_time'])\n",
    "            close_idx = np.where(np.abs(db_alert_time - alert_time) < 1)[0]\n",
    "            target_row = target_row[close_idx]\n",
    "        if len(target_row) == 0:\n",
    "            return None\n",
    "\n",
    "        if len(target_row) > 1:\n",
    "            print(f\"Multiple targets found. Returning the first one\")\n",
    "        \n",
    "        target_row = target_row[0]\n",
    "        trigger_time = target_row['trigger_time']\n",
    "        if trigger_time is None:\n",
    "            trigger_time = None\n",
    "        else:\n",
    "            trigger_time = Time(trigger_time)\n",
    "        \n",
    "        host_galaxy = target_row['host_galaxy']\n",
    "        if host_galaxy is None:\n",
    "            host_galaxy = None\n",
    "        else:\n",
    "            host_galaxy = str(host_galaxy)\n",
    "        \n",
    "        host_galaxy_distance = target_row['host_galaxy_distance']\n",
    "        if host_galaxy_distance is None:\n",
    "            host_galaxy_distance = None\n",
    "        else:\n",
    "            host_galaxy_distance = float(host_galaxy_distance)\n",
    "\n",
    "        host_galaxy_separation = target_row['host_galaxy_separation']\n",
    "        if host_galaxy_separation is None:\n",
    "            host_galaxy_separation = None\n",
    "        else:\n",
    "            host_galaxy_separation = float(host_galaxy_separation)\n",
    "        \n",
    "        mag_expected = target_row['mag_expected']\n",
    "        if mag_expected is None:\n",
    "            mag_expected = None\n",
    "        else:\n",
    "            mag_expected = float(mag_expected)\n",
    "        \n",
    "        absmag_expected = target_row['absmag_expected']\n",
    "        if absmag_expected is None:\n",
    "            absmag_expected = None\n",
    "        else:\n",
    "            absmag_expected = float(absmag_expected)\n",
    "        \n",
    "        note = target_row['note']\n",
    "        if note is None:\n",
    "            note = None\n",
    "        else:\n",
    "            note = str(note)\n",
    "        \n",
    "        input_dict = dict(target_row)\n",
    "        # If isinstance(Time), convert to isot\n",
    "        import datetime\n",
    "        input_dict = {key: Time(value).isot if isinstance(value, (Time, datetime.datetime)) else value for key, value in input_dict.items()}\n",
    "        # If not float, int, str, bool, None, remove\n",
    "        input_dict = {key: value for key, value in input_dict.items() if (np.isscalar(value)) or (value is None)}\n",
    "        \n",
    "        alert_instance = Alert(\n",
    "            alert_id = target_row['alert_id'],\n",
    "            objname = target_row['objname'],\n",
    "            cent_ra = target_row['cent_ra'],\n",
    "            cent_dec = target_row['cent_dec'],\n",
    "            radius = target_row['radius'],\n",
    "            \n",
    "            # AlertInfo\n",
    "            alert_time = target_row['alert_time'],\n",
    "            create_time = target_row['create_time'],\n",
    "            exptime = target_row['exptime'],\n",
    "            count = target_row['count'],\n",
    "            obsmode = target_row['obsmode'],\n",
    "            filter_ = target_row['filter_'],\n",
    "            specmode = target_row['specmode'],\n",
    "            ntelescope = target_row['ntelescope'],\n",
    "            priority = target_row['priority'],\n",
    "            weight = target_row['weight'],\n",
    "            binning = target_row['binning'],\n",
    "            gain = target_row['gain'],\n",
    "            objtype = target_row['objtype'],\n",
    "            is_ToO = target_row['is_ToO'],\n",
    "            is_rapid_ToO = target_row['is_rapid_ToO'],\n",
    "            \n",
    "            note = target_row['note'],\n",
    "            host_galaxy = target_row['host_galaxy'],\n",
    "            host_galaxy_distance = target_row['host_galaxy_distance'],\n",
    "            host_galaxy_separation = target_row['host_galaxy_separation'],\n",
    "            mag_expected = target_row['mag_expected'],\n",
    "            absmag_expected = target_row['absmag_expected'])\n",
    "\n",
    "        return alert_instance\n",
    "    \n",
    "    def _print_progress(self, title, progress_dict, stop=None):\n",
    "        print(f\"\\n--- ALERT {title} Progress ---\")\n",
    "        for step, done in progress_dict.items():\n",
    "            checkbox = \"✅\" if done else \"⬜\"\n",
    "            print(f\"{checkbox} {step}\")\n",
    "        if stop:\n",
    "            print(f\"⚠️ Stopped: {stop}\")\n",
    "        print(\"-----------------------------\\n\")"
   ]
  },
  {
